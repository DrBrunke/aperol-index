# Kopiere diese Datei nach .env:  cp .env.example .env
# .env ist in .gitignore und wird NICHT eingecheckt.

# Optionaler Zugriffsschutz: beliebigen PIN/Token setzen.
# Leer lassen = keine Authentifizierung erforderlich.
AUTH_TOKEN=

# Google Maps JavaScript API Key (für die interaktive Karte im Browser).
# Key einschränken auf: Maps JavaScript API + HTTP-Referrer (deine Domain).
GOOGLE_MAPS_KEY=

# Google Places API Key (für die Restaurant-/POI-Suche).
# Key einschränken auf: Places API (New) + IP-Adresse des VPS.
# Darf derselbe Key wie GOOGLE_MAPS_KEY sein, wenn beide APIs aktiviert sind.
GOOGLE_API_KEY=

# Kostenschutz: maximale billbare Google-Aufrufe (Karte + Suche) pro Kalendermonat.
# Bei Erreichen wird die KOMPLETTE App bis zum Monatsersten gesperrt.
# Konservativ unter dem kostenlosen Google-Kontingent wählen. 0 = unbegrenzt (kein Schutz).
GOOGLE_MONTHLY_LIMIT=9000
