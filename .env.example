# Kopiere diese Datei nach .env:  cp .env.example .env
# .env ist in .gitignore und wird NICHT eingecheckt.

# ---------- Zugriffsschutz via FaceID / Passkey (WebAuthn) ----------
# REGISTER_CODE: Einmal-Code, der EINMAL pro neuem Gerät beim Einrichten der
# FaceID/Touch-ID eingegeben werden muss. Danach meldet sich das Gerät nur noch
# per FaceID an und bleibt (Session-Cookie) angemeldet.
# Leer lassen = Zugangsschutz komplett deaktiviert (App offen).
REGISTER_CODE=

# RP_ID = registrierbare Domain OHNE Protokoll/Port (muss zur aufrufenden Domain passen).
# RP_ORIGIN = vollständige Origin INKL. Protokoll. WebAuthn braucht HTTPS
# (Ausnahme: localhost). Hinter nginx mit TLS einfach die echte Domain eintragen.
# Beispiel Produktion:
#   RP_ID=aperol.example.com
#   RP_ORIGIN=https://aperol.example.com
RP_ID=localhost
RP_ORIGIN=http://localhost:3000
RP_NAME=Aperol Index

# "Angemeldet bleiben": Session-Lebensdauer in Tagen (Default 365).
SESSION_TTL_DAYS=365

# Google Maps JavaScript API Key (für die interaktive Karte im Browser).
# Key einschränken auf: Maps JavaScript API + HTTP-Referrer (deine Domain).
GOOGLE_MAPS_KEY=

# Google Places API Key (für die Restaurant-/POI-Suche).
# Key einschränken auf: Places API (New) + IP-Adresse des VPS.
# Darf derselbe Key wie GOOGLE_MAPS_KEY sein, wenn beide APIs aktiviert sind.
GOOGLE_API_KEY=

# Kostenschutz: maximale billbare Google-Aufrufe (Karte + Suche) pro Kalendermonat.
# Bei Erreichen wird die KOMPLETTE App bis zum Monatsersten gesperrt.
# Konservativ unter dem kostenlosen Google-Kontingent wählen. 0 = unbegrenzt (kein Schutz).
GOOGLE_MONTHLY_LIMIT=9000
